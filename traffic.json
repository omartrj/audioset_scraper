{
  "_comment": "STEP 2 — Traffic / ambient noise (street sounds, crowds OK, no sirens). Uses unbalanced_train_segments.csv because traffic noise is rare and we want to collect every available sample.",
  "download": {
    "targets":      ["Traffic noise, roadway noise"],
    "avoid":        ["Narration, monologue", "Speech synthesizer", "Music", "Alarm", "Siren", "Emergency vehicle"],
    "host":         "linux",
    "max_samples":  5000,
    "output_dir":   "traffic_noise",
    "metadata":     "metadata.csv",
    "batch_size":   5000,
    "csv_path":     "unbalanced_train_segments.csv",
    "ontology_path": "ontology.json"
  },
  "audio": {
    "sample_rate":  48000,
    "channels":     1,
    "min_duration": 8,
    "max_duration": 10
  },
  "browser": {
    "use_cookies":    false,
    "browser":        "firefox",
    "sleep_interval": [1, 3]
  }
}
